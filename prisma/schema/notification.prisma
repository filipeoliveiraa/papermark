model NotificationPreference {
  id        String @id @default(cuid())
  userId    String
  teamId    String
  type      String // "DOCUMENT_VIEW" | "DATAROOM_VIEW" | "BLOCKED_ACCESS" | "DATAROOM_UPLOAD" | "CONVERSATION_MESSAGE"
  frequency String @default("IMMEDIATE") // "IMMEDIATE" | "DAILY" | "WEEKLY" | "NEVER"

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, teamId, type])
  @@index([userId, teamId])
}

model NotificationDigest {
  id      String @id @default(cuid())
  userId  String
  teamId  String
  type    String // same values as NotificationPreference.type
  payload Json

  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, teamId, type, processedAt])
  @@index([createdAt])
}
